{
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@release-it/conventional-changelog": "^10.0.1",
    "release-it": "^19.0.2"
  },
  "scripts": {
    "release": "release-it"
  },
  "release-it": {
    "hooks": {
      "before:init": [
        "composer test"
      ]
    },
    "git": {
      "commitMessage": "chore(release): ${version}"
    },
    "github": {
      "release": true,
      "releaseName": "v${version}",
      "draft": false,
      "preRelease": false,
      "tokenRef": "GITHUB_TOKEN"
    },
    "npm": {
      "publish": false
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "infile": "CHANGELOG.md",
        "header": "# Changelog\n\nAll notable changes to this project will be documented in this file.\n\nThe format is based on [Keep a Changelog](https://keepachangelog.com/en/1.0.0/),\nand this project adheres to [Semantic Versioning](https://semver.org/spec/v2.0.0.html).\n",
        "preset": "angular",
        "types": {
          "feat": {
            "section": "Features"
          },
          "fix": {
            "section": "Bug Fixes"
          },
          "chore": {
            "section": "Miscellaneous Chores"
          },
          "refactor": {
            "section": "Code Refactoring"
          }
        }
      }
    }
  },
  "version": "0.0.0"
}
