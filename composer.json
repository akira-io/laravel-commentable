{
    "name": "akira/laravel-commentable",
    "description": "Commentable is a lightweight and flexible comment system package designed to seamlessly integrate into any Laravel project. Whether you’re building a blog, a forum, or a platform like DevHunter – this package makes it incredibly easy to make any model commentable.",
    "keywords": [
        "Akira",
        "laravel",
        "commentable"
    ],
    "homepage": "https://github.com/akira-io/laravel-commentable",
    "license": "MIT",
    "authors": [
        {
            "name": "Kidiatoliny",
            "email": "kidiatoliny@akira-io.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "spatie/laravel-package-tools": "^1.93",
        "illuminate/contracts": "^12.0 || ^13.0"
    },
    "require-dev": {
        "akira/laravel-debugger": "^1.3",
        "larastan/larastan": "^3.4",
        "laravel/pint": "^1.22",
        "nunomaduro/collision": "^8.8.0",
        "orchestra/testbench": "^10.8.0 || ^11.0.0",
        "peckphp/peck": "^0.3.0",
        "pestphp/pest": "^3.8.2 || ^4.0.0",
        "pestphp/pest-plugin-arch": "^3.1.1 || ^4.0.0",
        "pestphp/pest-plugin-laravel": "^3.2 || ^4.0.0",
        "pestphp/pest-plugin-type-coverage": "^3.5.1 || ^4.0.0",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan-deprecation-rules": "^2.0.2",
        "phpstan/phpstan-phpunit": "^2.0.6",
        "rector/rector": "^2.0.14"
    },
    "autoload": {
        "psr-4": {
            "Akira\\Commentable\\": "src/",
            "Akira\\Commentable\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Akira\\Commentable\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "lint": "pint",
        "refactor": "rector",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run",
        "test:types": "phpstan",
        "test:type-coverage": "pest --type-coverage --min=100 --compact",
        "test:coverage": "pest --parallel --coverage --compact --exactly=88.6",
        "test:typos": "peck",
        "test": [
            "@test:lint",
            "@test:refactor",
            "@test:typos",
            "@test:types",
            "@test:type-coverage",
            "@test:coverage"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Akira\\Commentable\\CommentableServiceProvider"
            ],
            "aliases": {
                "Commentable": "Akira\\Commentable\\Facades\\Commentable"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
